---
// src/layouts/Layout.astro
---
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Astro + data-chart</title>
    <style is:global>
      body { opacity: 0; font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; }
      body.ready { opacity: 1; transition: opacity 0.15s; }
    </style>
  </head>
  <body>
    <slot />
    <script>
      import 'data-chart';
      document.body.classList.add('ready');
    </script>
  </body>
</html>
