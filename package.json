{
  "name": "data-chart",
  "version": "1.1.0",
  "description": "Chart your tables. No JavaScript to write.",
  "type": "module",
  "main": "dist/data-chart.umd.cjs",
  "module": "dist/data-chart.js",
  "types": "dist/data-chart.d.ts",
  "exports": {
    ".": {
      "import": "./dist/data-chart.js",
      "require": "./dist/data-chart.umd.cjs"
    },
    "./css": "./dist/data-chart.css"
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/anti-fouc.css dist/data-chart.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/ tests/",
    "fmt": "oxfmt --write src/ tests/",
    "fmt:check": "oxfmt --check src/ tests/",
    "size": "node scripts/check-size.mjs",
    "docs:dev": "pnpm --filter data-chart-docs dev",
    "docs:build": "pnpm --filter data-chart-docs build",
    "prepublishOnly": "pnpm build && pnpm test && pnpm size"
  },
  "keywords": [
    "chart",
    "svg",
    "table",
    "data-attributes",
    "progressive-enhancement",
    "zero-dependency",
    "visualization",
    "dark-mode",
    "accessible"
  ],
  "author": "ryo-manba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryo-manba/data-chart.git"
  },
  "funding": "https://github.com/ryo-manba/data-chart?sponsor=1",
  "homepage": "https://ryo-manba.github.io/data-chart/",
  "bugs": {
    "url": "https://github.com/ryo-manba/data-chart/issues"
  },
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "happy-dom": "^16.7.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^0.16.0",
    "terser": "^5.46.1",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.1.0"
  }
}
