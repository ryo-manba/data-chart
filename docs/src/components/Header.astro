---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;
const isJa = currentPath.includes('/ja/') || currentPath.endsWith('/ja');
const homeHref = isJa ? `${base}ja/` : base;
const langLabel = isJa ? 'English' : '日本語';
const altPath = isJa ? base : `${base}ja/`;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href={homeHref} class="flex items-center gap-2 text-text hover:text-text no-underline">
      <svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
        <defs>
          <linearGradient id="logo-g1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#38bdf8"/>
            <stop offset="100%" stop-color="#7dd3fc"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="7" fill="#0a0a1f"/>
        <rect x="6" y="20" width="5" height="8" rx="1.5" fill="url(#logo-g1)" opacity="0.5"/>
        <rect x="13.5" y="14" width="5" height="14" rx="1.5" fill="url(#logo-g1)" opacity="0.7"/>
        <rect x="21" y="8" width="5" height="20" rx="1.5" fill="url(#logo-g1)"/>
      </svg>
      <span class="font-heading font-bold text-xl gradient-text">data-chart</span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      <a
        href={`${base}docs/getting-started/`}
        class:list={['text-sm font-medium transition-colors no-underline', currentPath.includes('/docs') ? 'text-text' : 'text-text-secondary hover:text-text']}
      >
        Docs
      </a>
      <a
        href={isJa ? `${base}ja/playground/` : `${base}playground/`}
        class:list={['text-sm font-medium transition-colors no-underline', currentPath.includes('/playground') ? 'text-text' : 'text-text-secondary hover:text-text']}
      >
        Playground
      </a>
      <a
        href={isJa ? `${base}ja/advanced/` : `${base}advanced/`}
        class:list={['text-sm font-medium transition-colors no-underline', currentPath.includes('/advanced') ? 'text-text' : 'text-text-secondary hover:text-text']}
      >
        Animations
      </a>
      <a
        href="https://www.npmjs.com/package/data-chart"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline"
      >
        npm
      </a>
      <a
        href="https://github.com/ryo-manba/data-chart"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline"
      >
        GitHub
      </a>
      <a
        href={altPath}
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline border-l border-border pl-6"
      >
        {langLabel}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-secondary hover:text-text"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg/95 backdrop-blur-md">
    <nav class="flex flex-col p-4 gap-3">
      <a href={`${base}docs/getting-started/`} class="text-sm font-medium text-text-secondary hover:text-text no-underline">Docs</a>
      <a href={isJa ? `${base}ja/playground/` : `${base}playground/`} class="text-sm font-medium text-text-secondary hover:text-text no-underline">Playground</a>
      <a href={isJa ? `${base}ja/advanced/` : `${base}advanced/`} class="text-sm font-medium text-text-secondary hover:text-text no-underline">Animations</a>
      <a href="https://www.npmjs.com/package/data-chart" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-text-secondary hover:text-text no-underline">npm</a>
      <a href="https://github.com/ryo-manba/data-chart" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-text-secondary hover:text-text no-underline">GitHub</a>
      <a href={altPath} class="text-sm font-medium text-text-secondary hover:text-text no-underline border-t border-border pt-3">{langLabel}</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
