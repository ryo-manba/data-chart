---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

const sections = [
  {
    title: 'Getting Started',
    links: [
      { href: `${base}docs/getting-started/`, label: 'Installation & Setup' },
    ],
  },
  {
    title: 'Core Concepts',
    links: [
      { href: `${base}docs/chart-types/`, label: 'Chart Types' },
      { href: `${base}docs/attributes/`, label: 'Attributes' },
      { href: `${base}docs/animation/`, label: 'Animation' },
    ],
  },
  {
    title: 'Advanced',
    links: [
      { href: `${base}docs/api/`, label: 'JavaScript API' },
      { href: `${base}docs/typescript/`, label: 'TypeScript' },
      { href: `${base}docs/anti-fouc/`, label: 'Anti-FOUC' },
    ],
  },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href.replace(/\/$/, '');
}

function isSectionActive(links: { href: string }[]): boolean {
  return links.some(link => isActive(link.href));
}
---

<!-- Mobile sidebar overlay -->
<div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/50 hidden" aria-hidden="true"></div>

<!-- Mobile sidebar -->
<aside id="mobile-sidebar" class="lg:hidden fixed top-16 left-0 bottom-0 z-40 w-[280px] bg-bg border-r border-border -translate-x-full transition-transform duration-200 overflow-y-auto">
  <nav class="p-4 pb-8">
    {sections.map((section) => (
      <details open={isSectionActive(section.links) || true} class="sidebar-section mb-4">
        <summary class="flex items-center justify-between text-sm font-semibold uppercase tracking-wider text-text-secondary mb-2 py-1 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
          {section.title}
          <svg class="sidebar-chevron w-4 h-4 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </summary>
        <ul class="space-y-1 ml-3">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block text-[15px] py-1.5 px-3 rounded-md no-underline transition-colors',
                  isActive(link.href)
                    ? 'bg-accent/10 border-l-2 border-accent font-medium sidebar-active'
                    : 'text-text hover:text-accent-readable hover:bg-bg-hover',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</aside>

<!-- Desktop sidebar -->
<aside class="w-[260px] shrink-0 hidden lg:block">
  <nav class="sticky top-20 overflow-y-auto max-h-[calc(100vh-5rem)] pb-8 pr-4">
    {sections.map((section) => (
      <details open={isSectionActive(section.links) || true} class="sidebar-section mb-4">
        <summary class="flex items-center justify-between text-sm font-semibold uppercase tracking-wider text-text-secondary mb-2 py-1 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
          {section.title}
          <svg class="sidebar-chevron w-4 h-4 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </summary>
        <ul class="space-y-1 ml-3">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block text-[15px] py-1.5 px-3 rounded-md no-underline transition-colors',
                  isActive(link.href)
                    ? 'bg-accent/10 border-l-2 border-accent font-medium sidebar-active'
                    : 'text-text hover:text-accent-readable hover:bg-bg-hover',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</aside>

<style>
  .sidebar-section[open] > summary > .sidebar-chevron {
    transform: rotate(90deg);
  }
</style>

<script>
  function initSidebar() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('mobile-sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    if (!toggle || !sidebar || !overlay) return;

    function open() {
      sidebar!.classList.remove('-translate-x-full');
      overlay!.classList.remove('hidden');
      toggle!.querySelector('svg')!.style.transform = 'rotate(90deg)';
    }
    function close() {
      sidebar!.classList.add('-translate-x-full');
      overlay!.classList.add('hidden');
      toggle!.querySelector('svg')!.style.transform = '';
    }

    toggle.addEventListener('click', () => {
      sidebar!.classList.contains('-translate-x-full') ? open() : close();
    });
    overlay.addEventListener('click', close);
  }

  initSidebar();
  document.addEventListener('astro:after-swap', initSidebar);
</script>
