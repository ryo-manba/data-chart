---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Animations - data-chart">
  <Header />
  <div class="min-h-screen">
    <!-- Header -->
    <section class="px-6 pt-28 pb-16 max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest uppercase text-accent-readable mb-3">Animations</p>
      <h1 class="text-5xl font-heading font-extrabold tracking-tight sm:text-6xl text-text">
        Charts that <span class="text-accent-readable italic">come alive</span>
      </h1>
      <p class="mt-6 text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Add <code class="bg-bg-surface px-1.5 py-0.5 rounded text-sm font-mono text-accent">data-chart-animate</code> to any table. Bars grow, lines draw, slices appear. Pure CSS, no extra dependencies.
      </p>
    </section>

    <!-- How it works -->
    <section class="px-6 py-16 max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-heading font-bold text-text">How it works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="glass-card p-6 text-center">
          <div class="text-3xl mb-3">1</div>
          <h3 class="font-heading font-bold text-text">Add the attribute</h3>
          <p class="mt-2 text-sm text-text-secondary">Just add <code class="text-accent-readable text-xs font-mono">data-chart-animate</code> to your table element.</p>
        </div>
        <div class="glass-card p-6 text-center">
          <div class="text-3xl mb-3">2</div>
          <h3 class="font-heading font-bold text-text">CSS animations applied</h3>
          <p class="mt-2 text-sm text-text-secondary">data-chart adds the <code class="text-accent-readable text-xs font-mono">.dc-anim</code> class and stagger delays to SVG elements.</p>
        </div>
        <div class="glass-card p-6 text-center">
          <div class="text-3xl mb-3">3</div>
          <h3 class="font-heading font-bold text-text">Respects motion prefs</h3>
          <p class="mt-2 text-sm text-text-secondary"><code class="text-accent-readable text-xs font-mono">prefers-reduced-motion</code> disables all animations automatically.</p>
        </div>
      </div>
    </section>

    <!-- Live Examples -->
    <section class="px-6 py-20 max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase text-accent-readable mb-3">Live Examples</p>
        <h2 class="text-4xl font-heading font-bold text-text">Every chart type, animated</h2>
        <p class="mt-4 text-text-secondary max-w-xl mx-auto">
          Each chart below uses <code class="bg-bg-surface px-1.5 py-0.5 rounded text-xs font-mono text-accent">data-chart-animate</code>. Bars grow up, lines draw across, dots fade in, slices scale in.
        </p>
      </div>

      <div class="space-y-12">
        <!-- Bar: bars grow from baseline -->
        <div class="glass-card overflow-hidden">
          <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-heading font-bold text-text">Bar Chart</h3>
              <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay animation">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                Replay
              </button>
            </div>
            <div class="flex gap-2">
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">bar</span>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-border">
              <p class="text-xs text-text-muted mb-3">Bars grow from the baseline with staggered delays</p>
              <div class="chart-demo">
                <table data-chart="bar" data-chart-animate>
                  <caption>Quarterly Revenue</caption>
                  <thead><tr><th>Quarter</th><th>Revenue</th><th>Profit</th></tr></thead>
                  <tbody>
                    <tr><td>Q1</td><td>420</td><td>180</td></tr>
                    <tr><td>Q2</td><td>580</td><td>240</td></tr>
                    <tr><td>Q3</td><td>510</td><td>210</td></tr>
                    <tr><td>Q4</td><td>690</td><td>310</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="p-6 flex items-center">
              <pre class="bg-code-bg rounded-xl p-4 text-sm overflow-x-auto leading-relaxed w-full"><code>&lt;<span class="text-accent-readable">table</span> <span class="text-accent">data-chart</span>=<span class="text-emerald-400">"bar"</span>
       <span class="text-accent">data-chart-animate</span>&gt;
  ...
&lt;/<span class="text-accent-readable">table</span>&gt;</code></pre>
            </div>
          </div>
        </div>

        <!-- Line: stroke draws left to right -->
        <div class="glass-card overflow-hidden">
          <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-heading font-bold text-text">Line Chart</h3>
              <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay animation">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                Replay
              </button>
            </div>
            <div class="flex gap-2">
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">line</span>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-border">
              <p class="text-xs text-text-muted mb-3">Line draws from left to right, then dots fade in sequentially</p>
              <div class="chart-demo">
                <table data-chart="line" data-chart-animate>
                  <caption>Monthly Users</caption>
                  <thead><tr><th>Month</th><th>Users</th><th>Active</th></tr></thead>
                  <tbody>
                    <tr><td>Jan</td><td>1200</td><td>900</td></tr>
                    <tr><td>Feb</td><td>1800</td><td>1400</td></tr>
                    <tr><td>Mar</td><td>1500</td><td>1100</td></tr>
                    <tr><td>Apr</td><td>2200</td><td>1800</td></tr>
                    <tr><td>May</td><td>2800</td><td>2200</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="p-6 flex items-center">
              <pre class="bg-code-bg rounded-xl p-4 text-sm overflow-x-auto leading-relaxed w-full"><code>&lt;<span class="text-accent-readable">table</span> <span class="text-accent">data-chart</span>=<span class="text-emerald-400">"line"</span>
       <span class="text-accent">data-chart-animate</span>&gt;
  ...
&lt;/<span class="text-accent-readable">table</span>&gt;</code></pre>
            </div>
          </div>
        </div>

        <!-- Area: line draws + fill fades -->
        <div class="glass-card overflow-hidden">
          <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-heading font-bold text-text">Area Chart</h3>
              <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay animation">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                Replay
              </button>
            </div>
            <div class="flex gap-2">
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">area</span>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-border">
              <p class="text-xs text-text-muted mb-3">Line draws across, then the area fill fades in beneath</p>
              <div class="chart-demo">
                <table data-chart="area" data-chart-animate>
                  <caption>Weekly Visitors</caption>
                  <thead><tr><th>Week</th><th>Visitors</th></tr></thead>
                  <tbody>
                    <tr><td>W1</td><td>3200</td></tr>
                    <tr><td>W2</td><td>4100</td></tr>
                    <tr><td>W3</td><td>3800</td></tr>
                    <tr><td>W4</td><td>5200</td></tr>
                    <tr><td>W5</td><td>4800</td></tr>
                    <tr><td>W6</td><td>5900</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="p-6 flex items-center">
              <pre class="bg-code-bg rounded-xl p-4 text-sm overflow-x-auto leading-relaxed w-full"><code>&lt;<span class="text-accent-readable">table</span> <span class="text-accent">data-chart</span>=<span class="text-emerald-400">"area"</span>
       <span class="text-accent">data-chart-animate</span>&gt;
  ...
&lt;/<span class="text-accent-readable">table</span>&gt;</code></pre>
            </div>
          </div>
        </div>

        <!-- Pie & Donut side by side -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Pie -->
          <div class="glass-card overflow-hidden">
            <div class="px-6 py-4 border-b border-border flex items-center justify-between">
              <div class="flex items-center gap-3">
                <h3 class="font-heading font-bold text-text">Pie</h3>
                <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                  Replay
                </button>
              </div>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
            <div class="p-6">
              <p class="text-xs text-text-muted mb-3">Slices scale in one by one</p>
              <div class="chart-demo">
                <table data-chart="pie" data-chart-animate>
                  <caption>Browser Share</caption>
                  <thead><tr><th>Browser</th><th>Share</th></tr></thead>
                  <tbody>
                    <tr><td>Chrome</td><td>65</td></tr>
                    <tr><td>Safari</td><td>19</td></tr>
                    <tr><td>Firefox</td><td>10</td></tr>
                    <tr><td>Other</td><td>6</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Donut -->
          <div class="glass-card overflow-hidden">
            <div class="px-6 py-4 border-b border-border flex items-center justify-between">
              <div class="flex items-center gap-3">
                <h3 class="font-heading font-bold text-text">Donut</h3>
                <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                  Replay
                </button>
              </div>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
            <div class="p-6">
              <p class="text-xs text-text-muted mb-3">Segments scale in with staggered delay</p>
              <div class="chart-demo">
                <table data-chart="donut" data-chart-animate>
                  <caption>Budget Allocation</caption>
                  <thead><tr><th>Category</th><th>Budget</th></tr></thead>
                  <tbody>
                    <tr><td>Engineering</td><td>45</td></tr>
                    <tr><td>Marketing</td><td>25</td></tr>
                    <tr><td>Sales</td><td>20</td></tr>
                    <tr><td>Support</td><td>10</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Stacked bar -->
        <div class="glass-card overflow-hidden">
          <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-heading font-bold text-text">Stacked Bar</h3>
              <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                Replay
              </button>
            </div>
            <div class="flex gap-2">
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">bar</span>
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">data-chart-stacked</span>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-border">
              <p class="text-xs text-text-muted mb-3">Stacked segments grow from baseline together</p>
              <div class="chart-demo">
                <table data-chart="bar" data-chart-stacked data-chart-animate>
                  <caption>Device Traffic</caption>
                  <thead><tr><th>Q</th><th>Desktop</th><th>Mobile</th><th>Tablet</th></tr></thead>
                  <tbody>
                    <tr><td>Q1</td><td>300</td><td>200</td><td>50</td></tr>
                    <tr><td>Q2</td><td>280</td><td>250</td><td>60</td></tr>
                    <tr><td>Q3</td><td>260</td><td>300</td><td>70</td></tr>
                    <tr><td>Q4</td><td>320</td><td>350</td><td>80</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="p-6 flex items-center">
              <pre class="bg-code-bg rounded-xl p-4 text-sm overflow-x-auto leading-relaxed w-full"><code>&lt;<span class="text-accent-readable">table</span> <span class="text-accent">data-chart</span>=<span class="text-emerald-400">"bar"</span>
       <span class="text-accent">data-chart-stacked</span>
       <span class="text-accent">data-chart-animate</span>&gt;
  ...
&lt;/<span class="text-accent-readable">table</span>&gt;</code></pre>
            </div>
          </div>
        </div>

        <!-- Horizontal bar -->
        <div class="glass-card overflow-hidden">
          <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-heading font-bold text-text">Horizontal Bar</h3>
              <button type="button" class="replay-btn text-xs text-text-secondary hover:text-accent-readable transition-colors cursor-pointer flex items-center gap-1" aria-label="Replay">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
                Replay
              </button>
            </div>
            <div class="flex gap-2">
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">bar</span>
              <span class="border border-border text-text-secondary rounded-full px-3 py-1 text-xs font-mono">data-chart-horizontal</span>
              <span class="bg-accent/20 text-accent rounded-full px-3 py-1 text-xs font-mono">data-chart-animate</span>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-6 border-b lg:border-b-0 lg:border-r border-border">
              <p class="text-xs text-text-muted mb-3">Horizontal bars grow from left with stagger</p>
              <div class="chart-demo">
                <table data-chart="bar" data-chart-horizontal data-chart-animate>
                  <caption>Language Popularity</caption>
                  <thead><tr><th>Language</th><th>Users</th></tr></thead>
                  <tbody>
                    <tr><td>TypeScript</td><td>850</td></tr>
                    <tr><td>Python</td><td>720</td></tr>
                    <tr><td>Go</td><td>510</td></tr>
                    <tr><td>Rust</td><td>340</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="p-6 flex items-center">
              <pre class="bg-code-bg rounded-xl p-4 text-sm overflow-x-auto leading-relaxed w-full"><code>&lt;<span class="text-accent-readable">table</span> <span class="text-accent">data-chart</span>=<span class="text-emerald-400">"bar"</span>
       <span class="text-accent">data-chart-horizontal</span>
       <span class="text-accent">data-chart-animate</span>&gt;
  ...
&lt;/<span class="text-accent-readable">table</span>&gt;</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Animation Reference -->
    <section class="px-6 py-20 max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase text-accent-readable mb-3">Reference</p>
        <h2 class="text-4xl font-heading font-bold text-text">Animation Details</h2>
      </div>

      <div class="max-w-3xl mx-auto glass-card overflow-hidden">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="px-6 py-4 text-xs font-semibold tracking-widest uppercase text-text-secondary">Element</th>
              <th class="px-6 py-4 text-xs font-semibold tracking-widest uppercase text-text-secondary">Animation</th>
              <th class="px-6 py-4 text-xs font-semibold tracking-widest uppercase text-text-secondary">Duration</th>
              <th class="px-6 py-4 text-xs font-semibold tracking-widest uppercase text-text-secondary">Stagger</th>
            </tr>
          </thead>
          <tbody class="text-text-secondary">
            <tr class="border-b border-border-light">
              <td class="px-6 py-4 font-mono text-accent-readable text-xs">.data-chart-bar</td>
              <td class="px-6 py-4 text-text-secondary">scaleY(0 &rarr; 1) from baseline</td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">0.6s</span></td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">60ms</span></td>
            </tr>
            <tr class="border-b border-border-light">
              <td class="px-6 py-4 font-mono text-accent-readable text-xs">.data-chart-line</td>
              <td class="px-6 py-4 text-text-secondary">stroke-dashoffset draw</td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">1.0s</span></td>
              <td class="px-6 py-4 text-text-muted">-</td>
            </tr>
            <tr class="border-b border-border-light">
              <td class="px-6 py-4 font-mono text-accent-readable text-xs">.data-chart-dot</td>
              <td class="px-6 py-4 text-text-secondary">opacity(0 &rarr; 1)</td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">0.3s</span></td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">80ms</span> after 800ms</td>
            </tr>
            <tr class="border-b border-border-light">
              <td class="px-6 py-4 font-mono text-accent-readable text-xs">.data-chart-area</td>
              <td class="px-6 py-4 text-text-secondary">opacity(0 &rarr; 1)</td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">0.8s</span></td>
              <td class="px-6 py-4 text-text-muted">400ms delay</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-mono text-accent-readable text-xs">.data-chart-slice</td>
              <td class="px-6 py-4 text-text-secondary">scale(0.85 &rarr; 1) + opacity</td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">0.5s</span></td>
              <td class="px-6 py-4"><span class="bg-bg-surface rounded-full px-2 py-0.5 text-xs font-mono">120ms</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="max-w-3xl mx-auto mt-6 glass-card p-4 flex gap-3">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="flex-shrink-0 mt-0.5" aria-hidden="true">
          <circle cx="10" cy="10" r="8" stroke="#0ea5e9" stroke-width="1.5" fill="none" />
          <path d="M10 6v5M10 13v1" stroke="#0ea5e9" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <p class="text-sm text-text-secondary">
          All animations are automatically disabled when <code class="text-accent-readable text-xs font-mono">prefers-reduced-motion: reduce</code> is set. No additional configuration needed.
        </p>
      </div>
    </section>
  </div>

  <script>
    import dataChart from '../../../src/index.ts';

    document.querySelectorAll('.replay-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.glass-card');
        if (!card) return;
        const table = card.querySelector('table[data-chart]') as HTMLTableElement | null;
        if (table) dataChart.refresh(table);
      });
    });
  </script>
  <Footer />
</Layout>
