---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Animation" description="Add entrance animations to your charts with a single attribute.">
  <h1>Animation</h1>
  <p>Add <code>data-chart-animate</code> to any table for entrance animations. Each chart type has its own animation style.</p>

  <h2>Quick Start</h2>
  <pre><code>&lt;table data-chart="bar" data-chart-animate&gt;
  ...
&lt;/table&gt;</code></pre>

  <!-- Live Examples -->
  <h2>Live Examples</h2>
  <p>Click <strong>Replay</strong> to re-run any animation. Switch to <strong>Code</strong> to see the HTML source.</p>

  <div class="demo-grid">
    <!-- Bar Chart -->
    <div class="demo-card">
      <div class="demo-header">
        <h3>Bar Chart</h3>
        <div class="demo-actions">
          <div class="demo-tabs">
            <button type="button" class="tab-btn active" data-tab="preview">Preview</button>
            <button type="button" class="tab-btn" data-tab="code">Code</button>
          </div>
          <button type="button" class="action-btn copy-btn" hidden aria-label="Copy code">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy
          </button>
          <button type="button" class="action-btn replay-btn" aria-label="Replay animation">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 7a6 6 0 1 1 1.76 4.24"/><polyline points="1 11.5 1 7.5 5 7.5"/></svg>
            Replay
          </button>
        </div>
      </div>
      <p class="demo-desc">Bars grow from the baseline with staggered delays</p>
      <div class="demo-chart demo-chart--cartesian" data-panel="preview">
        <table data-chart="bar" data-chart-animate>
          <caption>Quarterly Revenue</caption>
