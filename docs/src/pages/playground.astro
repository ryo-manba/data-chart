---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Playground - data-chart">
  <Header />
  <div class="min-h-screen">
    <!-- Header -->
    <section class="px-6 pt-28 pb-10 max-w-5xl mx-auto text-center">
      <h1 class="text-4xl font-heading font-extrabold tracking-tight text-text">Playground</h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Choose a chart type and customize options. Edit the table data to see live changes.
      </p>
    </section>

    <!-- Main content -->
    <section class="px-6 pb-20 max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Left column: Preview + Generated HTML -->
        <div class="space-y-6">

          <!-- Preview card -->
          <div class="glass-card p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-heading font-semibold text-text">Preview</h2>
              <button
                type="button"
                id="replay-btn"
                class="chip-btn flex items-center gap-1.5"
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M1 7a6 6 0 1 1 1.76 4.24"/>
                  <polyline points="1 11.5 1 7.5 5 7.5"/>
                </svg>
                Replay
              </button>
            </div>
            <div id="chart-preview" class="min-h-[300px] flex items-center justify-center">
              <table id="playground-table" data-chart="bar" data-chart-grid="y" data-chart-legend="top" data-chart-radius="3">
                <thead>
                  <tr>
                    <th>Month</th>
                    <th>Revenue</th>
                    <th>Expenses</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td>Jan</td><td>120</td><td>80</td></tr>
                  <tr><td>Feb</td><td>150</td><td>95</td></tr>
                  <tr><td>Mar</td><td>180</td><td>110</td></tr>
                  <tr><td>Apr</td><td>210</td><td>130</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Generated HTML card -->
          <div class="glass-card p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-heading font-semibold text-text">Generated HTML</h2>
              <button
                type="button"
                id="copy-btn"
                class="chip-btn"
              >
                Copy
              </button>
            </div>
            <pre class="bg-code-bg border border-border rounded-lg p-4 text-sm text-text-secondary font-mono overflow-x-auto leading-relaxed max-h-[300px] overflow-y-auto"><code id="generated-code"></code></pre>
          </div>
        </div>

        <!-- Right column: Controls -->
        <div class="space-y-6">

          <!-- Chart Type card -->
          <div class="glass-card p-6">
            <h2 class="text-sm font-heading font-bold text-text mb-3">Chart Type</h2>
            <div class="flex flex-wrap gap-2" id="chart-type-group">
              <button type="button" class="pill-btn active" data-group="chart-type" data-value="bar">bar</button>
              <button type="button" class="pill-btn" data-group="chart-type" data-value="line">line</button>
              <button type="button" class="pill-btn" data-group="chart-type" data-value="area">area</button>
              <button type="button" class="pill-btn" data-group="chart-type" data-value="pie">pie</button>
              <button type="button" class="pill-btn" data-group="chart-type" data-value="donut">donut</button>
              <button type="button" class="pill-btn" data-group="chart-type" data-value="horizontal-bar">horizontal bar</button>
            </div>
          </div>

          <!-- Options card -->
          <div class="glass-card p-6">
            <h2 class="text-sm font-heading font-bold text-text mb-4">Options</h2>

            <!-- Grid -->
            <div class="mb-4">
              <label class="text-sm text-text-secondary mb-2 block">Grid</label>
              <div class="flex flex-wrap gap-2" id="grid-group">
                <button type="button" class="pill-btn active" data-group="grid" data-value="y">y</button>
                <button type="button" class="pill-btn" data-group="grid" data-value="x">x</button>
                <button type="button" class="pill-btn" data-group="grid" data-value="both">both</button>
                <button type="button" class="pill-btn" data-group="grid" data-value="none">none</button>
              </div>
            </div>

            <!-- Legend -->
            <div class="mb-4">
              <label class="text-sm text-text-secondary mb-2 block">Legend</label>
              <div class="flex flex-wrap gap-2" id="legend-group">
                <button type="button" class="pill-btn active" data-group="legend" data-value="top">top</button>
                <button type="button" class="pill-btn" data-group="legend" data-value="bottom">bottom</button>
                <button type="button" class="pill-btn" data-group="legend" data-value="none">none</button>
              </div>
            </div>

            <!-- Radius -->
            <div class="mb-4">
              <label class="text-sm text-text-secondary mb-2 block">
                Radius <span id="radius-value" class="text-text font-mono ml-1">3</span>
              </label>
              <input
                type="range"
                id="radius-input"
                min="0"
                max="12"
                value="3"
                class="w-full accent-accent"
              />
            </div>

            <!-- Stacked -->
            <div class="flex items-center gap-3">
              <label class="text-sm text-text-secondary">Stacked</label>
              <input
                type="checkbox"
                id="stacked-input"
                class="w-4 h-4 accent-accent rounded"
              />
            </div>
          </div>

          <!-- Animation card -->
          <div class="glass-card p-6">
            <h2 class="text-sm font-heading font-bold text-text mb-4">Animation</h2>

            <!-- Animate toggle -->
            <div class="flex items-center gap-3 mb-4">
              <label class="text-sm text-text-secondary">Animate</label>
              <input
                type="checkbox"
                id="animate-input"
                class="w-4 h-4 accent-accent rounded"
              />
            </div>

            <!-- Duration slider -->
            <div class="mb-4" id="duration-group">
              <label class="text-sm text-text-muted mb-2 block">
                Duration <span id="duration-value" class="text-text font-mono ml-1">600ms</span>
              </label>
              <input
                type="range"
                id="duration-input"
                min="100"
                max="2000"
                step="50"
                value="600"
                class="w-full accent-accent"
                disabled
              />
            </div>

            <!-- Stagger slider -->
            <div id="stagger-group">
              <label class="text-sm text-text-muted mb-2 block">
                Stagger <span id="stagger-value" class="text-text font-mono ml-1">60ms</span>
              </label>
              <input
                type="range"
                id="stagger-input"
                min="10"
                max="200"
                step="10"
                value="60"
                class="w-full accent-accent"
                disabled
              />
            </div>
          </div>

          <!-- Colors card -->
          <div class="glass-card p-6">
            <h2 class="text-sm font-heading font-bold text-text mb-3">Colors</h2>
            <div class="flex flex-wrap gap-2" id="colors-group">
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#2d5be3" data-color="#2d5be3" aria-label="Color #2d5be3"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#1a8c5a" data-color="#1a8c5a" aria-label="Color #1a8c5a"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#d94e3f" data-color="#d94e3f" aria-label="Color #d94e3f"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#c78a1e" data-color="#c78a1e" aria-label="Color #c78a1e"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#6b4ed4" data-color="#6b4ed4" aria-label="Color #6b4ed4"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#1a8c8c" data-color="#1a8c8c" aria-label="Color #1a8c8c"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#e05898" data-color="#e05898" aria-label="Color #e05898"></button>
              <button type="button" class="w-8 h-8 rounded-full border-2 border-transparent hover:border-white/50 transition-colors cursor-pointer" style="background:#4a90d9" data-color="#4a90d9" aria-label="Color #4a90d9"></button>
            </div>
          </div>

          <!-- Table Data card -->
          <div class="glass-card p-6">
            <h2 class="text-sm font-heading font-bold text-text mb-3">Table Data</h2>
            <textarea
              id="data-textarea"
              rows="12"
              class="w-full bg-code-bg border border-border rounded-lg p-4 text-sm text-text-secondary font-mono leading-relaxed resize-y focus:outline-none focus:border-accent transition-colors"
              spellcheck="false"
            ></textarea>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .pill-btn {
      padding: 0.375rem 0.875rem;
      border-radius: 9999px;
      font-size: 13px;
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
      cursor: pointer;
      border: 1px solid var(--color-border, #374151);
      background: transparent;
      color: var(--color-text-secondary, #9ca3af);
      transition: all 0.15s;
    }
    .pill-btn:hover {
      color: var(--color-text, #f3f4f6);
      border-color: var(--color-accent, #0ea5e9);
    }
    .pill-btn.active {
      background: color-mix(in srgb, var(--color-accent, #0ea5e9) 20%, transparent);
      border-color: var(--color-accent, #0ea5e9);
      color: #fff;
    }

    .chip-btn {
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
      font-size: 13px;
      padding: 7px 14px;
      border-radius: 8px;
      border: 1px solid var(--color-border, #374151);
      background: transparent;
      color: var(--color-text-secondary, #9ca3af);
      cursor: pointer;
      transition: all 0.15s;
    }
    .chip-btn:hover {
      border-color: var(--color-accent, #0ea5e9);
      color: var(--color-text, #f3f4f6);
    }

    #duration-group[data-disabled="true"] label,
    #stagger-group[data-disabled="true"] label {
      opacity: 0.4;
    }
    input[type="range"]:disabled {
      opacity: 0.4;
    }
  </style>

  <script>
    import dataChart from '../../../src/index.ts';

    const DEFAULT_TABLE_HTML = `<thead>
  <tr>
    <th>Month</th>
    <th>Revenue</th>
    <th>Expenses</th>
  </tr>
</thead>
<tbody>
  <tr><td>Jan</td><td>120</td><td>80</td></tr>
  <tr><td>Feb</td><td>150</td><td>95</td></tr>
  <tr><td>Mar</td><td>180</td><td>110</td></tr>
  <tr><td>Apr</td><td>210</td><td>130</td></tr>
</tbody>`;

    const DEFAULTS = {
      chartType: 'bar',
      grid: 'y',
      legend: 'top',
      radius: 3,
      stacked: false,
      animate: false,
      duration: 600,
      stagger: 60,
    };

    const table = document.getElementById('playground-table') as HTMLTableElement;
    const codeEl = document.getElementById('generated-code') as HTMLElement;
    const textarea = document.getElementById('data-textarea') as HTMLTextAreaElement;
    const radiusInput = document.getElementById('radius-input') as HTMLInputElement;
    const radiusValue = document.getElementById('radius-value') as HTMLSpanElement;
    const stackedInput = document.getElementById('stacked-input') as HTMLInputElement;
    const animateInput = document.getElementById('animate-input') as HTMLInputElement;
    const durationInput = document.getElementById('duration-input') as HTMLInputElement;
    const durationValue = document.getElementById('duration-value') as HTMLSpanElement;
    const staggerInput = document.getElementById('stagger-input') as HTMLInputElement;
    const staggerValue = document.getElementById('stagger-value') as HTMLSpanElement;
    const durationGroup = document.getElementById('duration-group') as HTMLDivElement;
    const staggerGroup = document.getElementById('stagger-group') as HTMLDivElement;
    const replayBtn = document.getElementById('replay-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

    let currentChartType = DEFAULTS.chartType;
    let currentGrid = DEFAULTS.grid;
    let currentLegend = DEFAULTS.legend;
    let currentRadius = DEFAULTS.radius;
    let currentStacked = DEFAULTS.stacked;
    let currentAnimate = DEFAULTS.animate;
    let currentDuration = DEFAULTS.duration;
    let currentStagger = DEFAULTS.stagger;
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    function setActivePill(group: string, value: string): void {
      const buttons = document.querySelectorAll<HTMLButtonElement>(`.pill-btn[data-group="${group}"]`);
      for (const btn of buttons) {
        if (btn.dataset.value === value) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      }
    }

    function updateStackedState(): void {
      const isBar = currentChartType === 'bar';
      stackedInput.disabled = !isBar;
      if (!isBar) {
        stackedInput.checked = false;
        currentStacked = false;
      }
      stackedInput.style.opacity = isBar ? '1' : '0.4';
    }

    function updateAnimationControls(): void {
      const enabled = currentAnimate;
      durationInput.disabled = !enabled;
      staggerInput.disabled = !enabled;
      durationGroup.setAttribute('data-disabled', String(!enabled));
      staggerGroup.setAttribute('data-disabled', String(!enabled));
    }

    function updateChart(): void {
      const isHorizontalBar = currentChartType === 'horizontal-bar';
      const chartAttr = isHorizontalBar ? 'bar' : currentChartType;

      table.setAttribute('data-chart', chartAttr);
      table.setAttribute('data-chart-grid', currentGrid);
      table.setAttribute('data-chart-legend', currentLegend);
      table.setAttribute('data-chart-radius', String(currentRadius));

      if (isHorizontalBar) {
        table.setAttribute('data-chart-horizontal', '');
      } else {
        table.removeAttribute('data-chart-horizontal');
      }

      if (currentStacked && currentChartType === 'bar') {
        table.setAttribute('data-chart-stacked', '');
      } else {
        table.removeAttribute('data-chart-stacked');
      }

      // Animation attributes
      if (currentAnimate) {
        table.setAttribute('data-chart-animate', '');
        table.setAttribute('data-chart-animate-duration', String(currentDuration));
        table.setAttribute('data-chart-animate-stagger', String(currentStagger));
      } else {
        table.removeAttribute('data-chart-animate');
        table.removeAttribute('data-chart-animate-duration');
        table.removeAttribute('data-chart-animate-stagger');
      }

      try {
        dataChart.refresh(table);
      } catch {
        // ignore render errors from invalid data
      }

      updateCode();
    }

    function formatHTML(html: string): string {
      let formatted = '';
      let indent = 0;
      const tags = html.replace(/>\s*</g, '>\n<').split('\n');
      for (const tag of tags) {
        if (tag.match(/^<\/(thead|tbody|tr|table)/)) indent--;
        formatted += '  '.repeat(Math.max(indent, 0)) + tag.trim() + '\n';
        if (tag.match(/^<(thead|tbody|tr|table)/) && !tag.match(/\/>/)) indent++;
      }
      return formatted.trim();
    }

    function generateTableHTML(): string {
      const isHorizontalBar = currentChartType === 'horizontal-bar';
      const chartAttr = isHorizontalBar ? 'bar' : currentChartType;

      let attrs = `data-chart="${chartAttr}"`;
      if (currentGrid !== 'y') attrs += ` data-chart-grid="${currentGrid}"`;
      if (currentLegend !== 'top') attrs += ` data-chart-legend="${currentLegend}"`;
      if (currentRadius !== 3) attrs += ` data-chart-radius="${currentRadius}"`;
      if (isHorizontalBar) attrs += ` data-chart-horizontal`;
      if (currentStacked && currentChartType === 'bar') attrs += ` data-chart-stacked`;
      if (currentAnimate) {
        attrs += ` data-chart-animate`;
        if (currentDuration !== 600) attrs += ` data-chart-animate-duration="${currentDuration}"`;
        if (currentStagger !== 60) attrs += ` data-chart-animate-stagger="${currentStagger}"`;
      }

      const raw = `<table ${attrs}>\n${table.innerHTML.trim()}\n</table>`;
      return formatHTML(raw);
    }

    function updateCode(): void {
      codeEl.textContent = generateTableHTML();
    }

    // --- Event listeners ---

    // Pill buttons
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.pill-btn') as HTMLButtonElement | null;
      if (!btn || !btn.dataset.group || !btn.dataset.value) return;

      const group = btn.dataset.group;
      const value = btn.dataset.value;

      setActivePill(group, value);

      if (group === 'chart-type') {
        currentChartType = value;
        updateStackedState();
      } else if (group === 'grid') {
        currentGrid = value;
      } else if (group === 'legend') {
        currentLegend = value;
      }

      updateChart();
    });

    // Radius slider
    radiusInput.addEventListener('input', () => {
      currentRadius = parseInt(radiusInput.value, 10);
      radiusValue.textContent = radiusInput.value;
      updateChart();
    });

    // Stacked toggle
    stackedInput.addEventListener('change', () => {
      currentStacked = stackedInput.checked;
      updateChart();
    });

    // Animate toggle
    animateInput.addEventListener('change', () => {
      currentAnimate = animateInput.checked;
      updateAnimationControls();
      updateChart();
    });

    // Duration slider
    durationInput.addEventListener('input', () => {
      currentDuration = parseInt(durationInput.value, 10);
      durationValue.textContent = currentDuration + 'ms';
      updateChart();
    });

    // Stagger slider
    staggerInput.addEventListener('input', () => {
      currentStagger = parseInt(staggerInput.value, 10);
      staggerValue.textContent = currentStagger + 'ms';
      updateChart();
    });

    // Textarea with debounce
    textarea.addEventListener('input', () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const value = textarea.value.trim();
        if (value) {
          table.innerHTML = value;
          updateChart();
        }
      }, 400);
    });

    // Replay button
    replayBtn.addEventListener('click', () => {
      dataChart.refresh(table);
    });

    // Copy button
    copyBtn.addEventListener('click', async () => {
      const html = generateTableHTML();
      try {
        await navigator.clipboard.writeText(html);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = original; }, 1500);
      } catch {
        // fallback: do nothing
      }
    });

    // Color circles
    const colorButtons = document.querySelectorAll<HTMLButtonElement>('#colors-group button');
    for (const btn of colorButtons) {
      btn.addEventListener('click', () => {
        btn.classList.toggle('border-white');
        btn.classList.toggle('border-transparent');
        const selected: string[] = [];
        for (const b of colorButtons) {
          if (b.classList.contains('border-white') && b.dataset.color) {
            selected.push(b.dataset.color);
          }
        }
        if (selected.length > 0) {
          table.setAttribute('data-chart-colors', selected.join(','));
        } else {
          table.removeAttribute('data-chart-colors');
        }
        updateChart();
      });
    }

    // --- Initialize ---
    textarea.value = DEFAULT_TABLE_HTML;
    updateStackedState();
    updateAnimationControls();
    setTimeout(() => {
      updateCode();
    }, 0);
  </script>
  <Footer />
</Layout>
